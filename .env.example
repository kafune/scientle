# Copie para `.env` e preencha. Em produção, o docker-compose lê este arquivo
# da raiz para interpolar as variáveis do serviço. NÃO commite o `.env` real.

# Senha do Postgres (serviço `db` do compose).
POSTGRES_PASSWORD="troque-esta-senha"

# Conexão usada pelo Prisma CLI / `next dev` LOCAL (fora do Docker).
# Dentro do compose, a DATABASE_URL do app é montada automaticamente apontando
# para o serviço `db`, então NÃO precisa editar aqui para produção.
DATABASE_URL="postgresql://spotle:troque-esta-senha@localhost:5432/spotle?schema=public"

# NextAuth (Auth.js v5)
# Gere com: openssl rand -base64 33
AUTH_SECRET=""
# URL pública canônica (com https em produção).
AUTH_URL="https://seu-dominio.com"
AUTH_TRUST_HOST="true"

# Credenciais OAuth do Google Cloud Console (APIs & Services > Credentials).
# Redirect URI autorizada: https://seu-dominio.com/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# (Opcional/secreto) Define o cientista do dia para datas específicas.
# JSON mapeando o "dia de jogo" (YYYY-MM-DD, régua do reset 21h) -> nome.
# Deixe vazio para sorteio normal. Ex.:
# DAILY_OVERRIDES={"2026-06-20":"Leo Testoni","2026-12-25":"Amanda Lanzotti"}
DAILY_OVERRIDES=
